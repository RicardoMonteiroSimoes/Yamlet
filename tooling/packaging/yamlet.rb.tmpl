# Template for the Homebrew formula. scripts/update-tap.sh fills the version and
# per-target checksum placeholders from a release build's SHA256SUMS and pushes
# the result to RicardoMonteiroSimoes/homebrew-yamlet as Formula/yamlet.rb.
#
# Do not edit the rendered formula in the tap repo by hand — it is overwritten
# on every release. Change this template instead.
class Yamlet < Formula
  desc "Verify and author yamlet specs"
  homepage "https://github.com/RicardoMonteiroSimoes/Yamlet"
  version "__VERSION__"
  license "MIT"

  on_macos do
    on_arm do
      url "https://github.com/RicardoMonteiroSimoes/Yamlet/releases/download/v__VERSION__/yamlet-__VERSION__-aarch64-apple-darwin.tar.gz"
      sha256 "__SHA_AARCH64_APPLE_DARWIN__"
    end
    on_intel do
      url "https://github.com/RicardoMonteiroSimoes/Yamlet/releases/download/v__VERSION__/yamlet-__VERSION__-x86_64-apple-darwin.tar.gz"
      sha256 "__SHA_X86_64_APPLE_DARWIN__"
    end
  end

  on_linux do
    on_arm do
      url "https://github.com/RicardoMonteiroSimoes/Yamlet/releases/download/v__VERSION__/yamlet-__VERSION__-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_AARCH64_UNKNOWN_LINUX_GNU__"
    end
    on_intel do
      url "https://github.com/RicardoMonteiroSimoes/Yamlet/releases/download/v__VERSION__/yamlet-__VERSION__-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_X86_64_UNKNOWN_LINUX_GNU__"
    end
  end

  def install
    bin.install "yamlet"
  end

  test do
    assert_match "yamlet __VERSION__", shell_output("#{bin}/yamlet --version")
  end
end
